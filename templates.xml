<Ui xmlns="http://www.blizzard.com/wow/ui/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">
    <Button name="HandyNotes_RitualSitesWorldMapOptionsButtonTemplate" virtual="true">
        <Size x="32" y="32"/>
        <Layers>
            <Layer level="ARTWORK">
                <Texture parentKey="Icon" file="Interface\Icons\Spell_Shadow_Rune">
                    <Size x="24" y="24"/>
                    <Anchors>
                        <Anchor point="CENTER"/>
                    </Anchors>
                </Texture>
            </Layer>
            <Layer level="OVERLAY">
                <Texture parentKey="Border" file="Interface\Minimap\MiniMap-TrackingBorder">
                    <Size x="54" y="54"/>
                    <Anchors>
                        <Anchor point="CENTER" x="11" y="-12"/>
                    </Anchors>
                </Texture>
            </Layer>
        </Layers>
        <HighlightTexture file="Interface\Buttons\ButtonHilight-Square" alphaMode="ADD"/>
    </Button>
</Ui>
